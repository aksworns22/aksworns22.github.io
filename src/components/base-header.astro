---
import SearchButton from '~/components/ui/search-button';

type Props = {
  title: string;
  description?: string;
  noI18n?: boolean;
};

const { props, url } = Astro;
const { title, description, noI18n } = props;
---

<header class="mb-7 font-serif">
  <div class="flex items-center justify-between">
    <h1 class="text-heading -mb-0.5 leading-7 font-semibold">
      {title} ﹒ aksworns22
    </h1>
  </div>
  {description && <p class="text-second text-sm">{description}</p>}
  <slot />
</header>
